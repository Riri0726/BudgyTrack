{
  "expo": {
    "name": "BudgyTrack",
    "slug": "budgytrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "budgytrack",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.budgytrack.app",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "BudgyTrack uses your location in the background to remind you to log expenses when you leave home.",
        "NSLocationWhenInUseUsageDescription": "BudgyTrack uses your location to set your home area for spending reminders.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.budgytrack.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f172a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BudgyTrack uses your location in the background to remind you to log expenses when you leave home.",
          "locationWhenInUsePermission": "BudgyTrack uses your location to set your home area for spending reminders.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3b82f6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
